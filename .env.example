# Default is local mode (no cloud keys required)
VITE_AUTH_MODE=local

# Optional: set if your API is hosted elsewhere. If empty, the app uses same-origin
# with Vite proxy during development.
# VITE_API_BASE_URL=http://localhost:5175

# Optional (only if VITE_AUTH_MODE=firebase)
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_AUTH_DOMAIN=...
# VITE_FIREBASE_PROJECT_ID=...
# VITE_FIREBASE_STORAGE_BUCKET=...
# VITE_FIREBASE_MESSAGING_SENDER_ID=...
# VITE_FIREBASE_APP_ID=...
