PORT=5175
CLIENT_ORIGIN=http://localhost:5173

# Default local/offline mode (stub AI + stub STT)
AUTH_MODE=local
JWT_SECRET=interviewverse-local-dev-secret

# AI provider keys (OpenAI preferred, Gemini fallback)
OPENAI_API_KEY=...
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-flash

# Firebase Admin credentials (choose ONE):
# Option A: paste the full service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option B: base64 encoded JSON (recommended for CI)
# FIREBASE_SERVICE_ACCOUNT_BASE64=...
